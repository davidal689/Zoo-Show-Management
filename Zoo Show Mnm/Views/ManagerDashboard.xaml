<UserControl x:Class="Zoo_Show_Mnm.Views.ManagerDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Zoo_Show_Mnm.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Background="#F0F0F0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Navigation Sidebar -->
        <Border Grid.Column="0" Background="#E0E0E0" BorderBrush="DarkGray" BorderThickness="0,0,1,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Manager Panel" FontSize="20" FontWeight="Bold" Foreground="Black" Margin="0,0,0,25"/>
                    <Button Content="Quản lý lịch Show" Height="35" Margin="0,0,0,10"/>
                </StackPanel>

                <Button Grid.Row="2" Content="Đăng xuất" Click="BtnLogout_Click" Height="30"/>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2.5*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Điều Phối Lịch Diễn" FontSize="20" FontWeight="Bold" Grid.Row="0" Margin="0,0,0,15"/>

            <!-- List Grid -->
            <DataGrid x:Name="GridShows" Grid.Row="1" SelectionChanged="GridShows_SelectionChanged" Margin="0,0,0,15" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên Show" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Địa điểm" Binding="{Binding Venue}" Width="150"/>
                    <DataGridTextColumn Header="Thời gian" Binding="{Binding DateTime, StringFormat='MM/dd/yyyy hh:mm tt'}" Width="150"/>
                    <DataGridTextColumn Header="Tổng ghế" Binding="{Binding SeatCapacity}" Width="80"/>
                    <DataGridTextColumn Header="Ghế trống" Binding="{Binding RemainingSeatCapacity}" Width="80"/>
                    <DataGridTextColumn Header="Giá vé" Binding="{Binding TicketPrice, StringFormat='${0:F2}'}" Width="80"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Action buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
                <Button Content="Tạo lịch diễn mới" Click="BtnNewShow_Click" Width="150" Margin="0,0,10,0" Height="30"/>
                <Button Content="Hủy lịch diễn này" Click="BtnCancelShow_Click" Width="150" Height="30"/>
            </StackPanel>

            <!-- Editor Form Panel -->
            <Border Grid.Row="3" Background="White" BorderBrush="DarkGray" BorderThickness="1" CornerRadius="5" Padding="15">
                <ScrollViewer>
                    <Grid>
                        <!-- No show selected view -->
                        <TextBlock x:Name="TxtNoSelection" Text="Chọn một show diễn từ danh sách hoặc click 'Tạo lịch diễn mới'." Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Edit form -->
                        <Grid x:Name="FormShow" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,15,10">
                                <Label Content="Tên Show diễn"/>
                                <TextBox x:Name="TxtShowName" Height="26" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,15,10">
                                <Label Content="Địa điểm"/>
                                <ComboBox x:Name="CbVenue" Height="26">
                                    <ComboBoxItem Content="Splash Amphitheater"/>
                                    <ComboBoxItem Content="Eagle Ridge Arena"/>
                                    <ComboBoxItem Content="Savannah Lookout"/>
                                    <ComboBoxItem Content="Nocturnal Jungle Dome"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,15,10">
                                <Label Content="Sức chứa (Ghế)"/>
                                <TextBox x:Name="TxtCapacity" Height="26" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="15,0,0,10">
                                <Label Content="Thời gian diễn (MM/dd/yyyy hh:mm AM/PM)"/>
                                <TextBox x:Name="TxtDateTime" Height="26" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="15,0,0,10">
                                <Label Content="Giá vé ($)"/>
                                <TextBox x:Name="TxtPrice" Height="26" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="2" Margin="15,0,0,10">
                                <Label Content="Trạng thái lịch đăng"/>
                                <ComboBox x:Name="CbStatus" Height="26">
                                    <ComboBoxItem Content="Draft"/>
                                    <ComboBoxItem Content="Published"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="3" Margin="0,5,0,15">
                                <Label Content="Mô tả chi tiết"/>
                                <TextBox x:Name="TxtDescription" AcceptsReturn="True" Height="50" VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>

                            <Grid Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0" x:Name="ChKConflict" Content="Bỏ qua cảnh báo trùng lịch địa điểm" VerticalAlignment="Center" Foreground="Orange" FontWeight="SemiBold"/>
                                <Button Grid.Column="1" Content="Lưu Lịch Diễn" Click="BtnSaveShow_Click" Width="150" Height="30" FontWeight="Bold"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
