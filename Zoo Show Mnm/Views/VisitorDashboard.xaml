<UserControl x:Class="Zoo_Show_Mnm.Views.VisitorDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Zoo_Show_Mnm.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Background="#F0F0F0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Navigation Sidebar -->
        <Border Grid.Column="0" Background="#E0E0E0" BorderBrush="DarkGray" BorderThickness="0,0,1,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Visitor Hub" FontSize="20" FontWeight="Bold" Foreground="Black" Margin="0,0,0,25"/>
                    <RadioButton x:Name="TabBrowse" Content="Danh sách Show" IsChecked="True" Checked="Tab_Checked" Height="35" Margin="0,0,0,5"/>
                    <RadioButton x:Name="TabHistory" Content="Vé của tôi" Checked="Tab_Checked" Height="35"/>
                </StackPanel>

                <Button Grid.Row="2" x:Name="BtnLogout" Content="Đăng xuất" Click="BtnLogout_Click" Height="30"/>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1" Margin="20">
            <!-- Tab: Browse Shows -->
            <Grid x:Name="ContentBrowse" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Filter Bar -->
                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,15">
                    <Label Content="Lọc theo ngày:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker x:Name="DpFilterDate" Width="150" Height="26" VerticalAlignment="Center"/>
                    <Button Content="Lọc" Click="BtnFilter_Click" Width="70" Height="26" Margin="10,0,5,0"/>
                    <Button Content="Xóa lọc" Click="BtnClearFilter_Click" Width="70" Height="26"/>
                </StackPanel>

                <!-- Shows Grid -->
                <DataGrid x:Name="GridShows" Grid.Row="1" Grid.Column="0" SelectionChanged="GridShows_SelectionChanged" Margin="0,0,15,0" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên Show" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Địa điểm" Binding="{Binding Venue}" Width="130"/>
                        <DataGridTextColumn Header="Thời gian" Binding="{Binding DateTime, StringFormat='MM/dd hh:mm tt'}" Width="110"/>
                        <DataGridTextColumn Header="Giá vé" Binding="{Binding TicketPrice, StringFormat='${0:F2}'}" Width="70"/>
                        <DataGridTextColumn Header="Ghế trống" Binding="{Binding RemainingSeatCapacity}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Show Detail / Booking Panel -->
                <Border Grid.Row="1" Grid.Column="1" Background="White" BorderBrush="DarkGray" BorderThickness="1" CornerRadius="5" Padding="15">
                    <Grid>
                        <!-- No show selected panel -->
                        <TextBlock x:Name="TxtNoShowSelected" Text="Chọn một show từ danh sách để xem chi tiết và đặt vé." Foreground="Gray" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>

                        <!-- Details panel -->
                        <ScrollViewer x:Name="PanelShowDetails" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="DetailsName" Text="Show Name" FontSize="16" FontWeight="Bold" Foreground="Black" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <TextBlock x:Name="DetailsDesc" Text="Description" Foreground="DimGray" TextWrapping="Wrap" LineHeight="1.4" Margin="0,0,0,15"/>
                                
                                <Separator Margin="0,0,0,15"/>
                                
                                <TextBlock x:Name="DetailsVenue" Text="Địa điểm: Splash Amphitheater" Foreground="Black" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock x:Name="DetailsDateTime" Text="Thời gian: 12/12/2026 14:00" Foreground="Black" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock x:Name="DetailsSeats" Text="Ghế còn trống: 100" Foreground="Black" FontSize="12" Margin="0,0,0,10"/>
                                
                                <TextBlock Text="Sơ đồ ghế ngồi:" FontWeight="Bold" FontSize="12" Margin="0,0,0,5" Foreground="Black"/>
                                <Border BorderBrush="LightGray" BorderThickness="1" Background="#FAFAFA" CornerRadius="4" Padding="10" Margin="0,0,0,15">
                                    <StackPanel>
                                        <!-- Legends -->
                                        <UniformGrid Columns="4" Margin="0,0,0,10">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Border Width="10" Height="10" Background="White" BorderBrush="DarkGray" BorderThickness="1" Margin="0,0,2,0"/>
                                                <TextBlock Text="Trống" FontSize="9" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Border Width="10" Height="10" Background="Red" BorderBrush="DarkRed" BorderThickness="1" Margin="0,0,2,0"/>
                                                <TextBlock Text="Đã đặt" FontSize="9" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Border Width="10" Height="10" Background="Yellow" BorderBrush="Goldenrod" BorderThickness="1" Margin="0,0,2,0"/>
                                                <TextBlock Text="Đang giữ" FontSize="9" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Border Width="10" Height="10" Background="DodgerBlue" BorderBrush="DarkBlue" BorderThickness="1" Margin="0,0,2,0"/>
                                                <TextBlock Text="Đang chọn" FontSize="9" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </UniformGrid>
                                        
                                        <!-- Seat Map dynamic container -->
                                        <WrapPanel x:Name="PanelSeatMap" ItemWidth="18" ItemHeight="18" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Purchase view state -->
                                <StackPanel x:Name="PanelPurchaseForm">
                                    <Label Content="Số lượng vé" Margin="0,0,0,2"/>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="-" Click="BtnQtyDec_Click" Width="30" Height="26"/>
                                        <TextBox Grid.Column="1" x:Name="TxtQty" Text="1" TextAlignment="Center" Height="26" Margin="5,0" VerticalContentAlignment="Center" IsReadOnly="True"/>
                                        <Button Grid.Column="2" Content="+" Click="BtnQtyInc_Click" Width="30" Height="26"/>
                                    </Grid>

                                    <Button x:Name="BtnBook" Content="Tiến Hành Đặt Vé" Click="BtnBook_Click" Height="32"/>
                                </StackPanel>

                                <!-- Checkout view state -->
                                <StackPanel x:Name="PanelCheckout" Visibility="Collapsed">
                                    <TextBlock Text="Đang Giữ Ghế Tạm Thời" FontWeight="Bold" Foreground="Orange" FontSize="13" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                                    <Border Background="#FFEAEA" BorderBrush="Red" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,15">
                                        <TextBlock x:Name="TxtTimer" Text="Hết hạn sau: 10:00" Foreground="Red" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </Border>

                                    <TextBlock x:Name="TxtCheckoutTotal" Text="Tổng tiền: $0.00" FontSize="15" FontWeight="Bold" Foreground="Green" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                                    <TextBlock Text="Giả lập thanh toán cổng Gateway:" FontSize="11" Foreground="Gray" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                                    <Button Content="Thanh toán THÀNH CÔNG" Click="BtnPaySuccess_Click" Height="30" Margin="0,0,0,8" FontWeight="Bold"/>
                                    <Button Content="Thanh toán THẤT BẠI / HỦY" Click="BtnPayFail_Click" Height="30"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Tab: Booking History -->
            <Grid x:Name="ContentHistory" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Lịch Sử Vé Đã Đặt" FontSize="20" FontWeight="Bold" Grid.Row="0" Margin="0,0,0,15"/>

                <DataGrid x:Name="GridHistory" Grid.Row="1" Margin="0,0,0,15" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã đặt vé" Binding="{Binding ReferenceNumber}" Width="100"/>
                        <DataGridTextColumn Header="Tên Show" Binding="{Binding Show.Name}" Width="*"/>
                        <DataGridTextColumn Header="Thời gian diễn" Binding="{Binding Show.DateTime, StringFormat='MM/dd hh:mm tt'}" Width="120"/>
                        <DataGridTextColumn Header="Ngày đặt vé" Binding="{Binding BookingDate, StringFormat='MM/dd hh:mm tt'}" Width="120"/>
                        <DataGridTextColumn Header="Số lượng" Binding="{Binding TicketQuantity}" Width="60"/>
                        <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TotalPrice, StringFormat='${0:F2}'}" Width="80"/>
                        <DataGridTextColumn Header="Trạng thái" Binding="{Binding StatusDisplay}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Button x:Name="BtnCancelBooking" Content="Yêu cầu hủy vé này" Click="BtnCancelBooking_Click" Width="180" Height="32" Margin="0,0,10,0"/>
                    <Button x:Name="BtnPayPending" Content="Thanh toán vé này" Click="BtnPayPending_Click" Width="180" Height="32" Background="Green" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
